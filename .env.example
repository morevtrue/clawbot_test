# Скопируй этот файл в .env и заполни значения
# cp .env.example .env

# ── AI провайдер ─────────────────────────────────────────────────────────────
# OpenRouter — бесплатные модели, карта не нужна
# Получить ключ: https://openrouter.ai → Keys
OPENROUTER_API_KEY=

# ── Токен шлюза ───────────────────────────────────────────────────────────────
# Оставь пустым — сгенерируется автоматически при первом запуске.
# После запуска найди его командой:
#   cat .docker/openclaw/config/openclaw.json | grep token
OPENCLAW_GATEWAY_TOKEN=

# ── Домен для доступа через Traefik ──────────────────────────────────────────
OPENCLAW_DOMAIN=
